generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// @map mantém os nomes das colunas no banco intactos — sem nova migration necessária
model Wallet {
  id           String   @id @default(uuid())
  jogadorId    String   @unique @map("playerId")   // "sub" do token JWT do Keycloak
  nomeUsuario  String   @map("username")           // "preferred_username" do JWT
  saldo        BigInt   @default(0) @map("balance") // centavos. R$1,50 = 150n. Nunca Float.
  criadoEm     DateTime @default(now()) @map("createdAt")
  atualizadoEm DateTime @updatedAt @map("updatedAt")

  @@map("wallets")
}
